---
import { Image } from "astro:assets";
import SocialIcon from "./SocialIcon.astro";
import { allEvents, todayIso } from "../data/events";

// Fecha local del build — NO usar toISOString (desfasa el día en Chile)
const buildTodayIso = todayIso();

// El próximo evento ahora viene de Supabase (client-side, ver <script> abajo).
// Los "últimos eventos" (curados a mano) siguen estáticos en events.ts.
const past = allEvents.filter((ev) => ev.iso < buildTodayIso);
---

<section
  id="eventos"
  class="py-section-gap bg-surface-container-low"
>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <!-- Header -->
    <div class="text-center mb-14">
      <span
        class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4"
      >
        Cartelera
      </span>
      <h2
        class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface"
      >
        Próximos eventos
      </h2>
    </div>

    <!-- Próximo evento: un único destacado, poblado client-side desde Supabase -->
    <div
      data-featured-event
      class="hidden reveal card-lift group overflow-hidden bg-surface-container border border-primary-container/10 flex flex-col max-w-sm md:max-w-md mx-auto mb-20"
    >
      <div class="overflow-hidden">
        <img
          data-featured-image
          alt=""
          class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>
      <div class="p-5 md:p-6">
        <span class="text-primary-container text-label-sm font-bold uppercase tracking-wider block mb-1">
          Próximo evento
        </span>
        <h3 class="font-headline-lg text-on-surface text-lg md:text-xl font-bold" data-featured-artist>
        </h3>
        <p class="text-on-surface-variant text-sm mt-1" data-featured-meta></p>
        <a
          href="#reserva"
          class="btn-shine inline-block mt-4 px-6 py-2 bg-primary-container text-on-primary-container text-xs font-bold tracking-widest uppercase text-center hover:brightness-110 active:scale-95 transition-all"
        >
          Reservar
        </a>
      </div>
    </div>

    <!-- Estado sin eventos futuros: visible por defecto (degradación honesta si JS falla/tarda) -->
    <div
      data-no-events
      class="reveal border border-primary-container/15 bg-surface-container text-center px-6 py-14 mb-20 max-w-2xl mx-auto"
    >
      <span
        class="material-symbols-outlined text-primary-container text-4xl mb-4"
        >calendar_month</span
      >
      <h3
        class="font-headline-lg text-on-surface text-2xl md:text-3xl font-bold mb-3"
      >
        Estamos preparando la próxima fecha
      </h3>
      <p class="text-on-surface-variant mb-8 max-w-md mx-auto">
        Muy pronto anunciaremos un nuevo show en la terraza. Escríbenos por
        WhatsApp y te avisamos con anticipación.
      </p>
      <a
        href="https://wa.me/56974131205?text=Hola!%20Quiero%20saber%20cuándo%20es%20el%20próximo%20evento"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-shine inline-block px-10 py-3 bg-primary-container text-on-primary-container text-sm font-bold tracking-widest uppercase hover:brightness-110 active:scale-95 transition-all"
      >
        Avísame del próximo evento
      </a>
    </div>

    <!-- Últimos eventos -->
    <div class="text-center mb-10">
      <span
        class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4"
      >
        Así se vive la terraza
      </span>
      <h3
        class="font-headline-lg text-on-surface text-2xl md:text-3xl font-bold"
      >
        Últimos eventos
      </h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {
        past.map((ev, i) => (
          <div
            class="reveal card-lift group overflow-hidden bg-surface-container border border-primary-container/10 flex flex-col"
            style={`--reveal-delay: ${i * 100}ms`}
          >
            <div class="overflow-hidden">
              <Image
                src={ev.image}
                alt={ev.artist}
                class="w-full h-auto transition-transform duration-700 group-hover:scale-105"
              />
            </div>
            <div class="p-5">
              <span class="text-primary-container text-label-sm font-bold uppercase tracking-wider block mb-1">
                {ev.date}
              </span>
              <h4 class="font-headline-lg text-on-surface text-lg font-bold">
                {ev.artist}
              </h4>
              <p class="text-on-surface-variant text-sm mt-1">{ev.genre}</p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- CTA WhatsApp -->
    <div class="text-center mt-10">
      <a
        href="https://wa.me/56974131205?text=Hola!%20Quiero%20saber%20más%20sobre%20la%20cartelera%20de%20eventos"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 hover:gap-3 text-primary-container font-semibold text-base md:text-lg hover:brightness-110 transition-all"
      >
        <SocialIcon
          platform="whatsapp"
          class="w-5 h-5 shrink-0"
        />
        <span
          class="underline underline-offset-4 decoration-primary-container/40 group-hover:decoration-primary-container transition-colors"
          >Consultar por más fechas vía WhatsApp</span
        >
      </a>
    </div>
  </div>
</section>

<script>
  import { supabase } from "../lib/supabase";

  interface Evento {
    artista: string;
    genero: string | null;
    fecha: string;
    hora: string;
    descripcion: string | null;
    imagen_url: string | null;
  }

  function formatFecha(iso: string): string {
    const [y, m, d] = iso.split("-").map(Number);
    const date = new Date(y, m - 1, d);
    const label = date.toLocaleDateString("es-CL", {
      weekday: "short",
      day: "numeric",
      month: "short",
    });
    return label.charAt(0).toUpperCase() + label.slice(1).replace(".", "");
  }

  async function loadFeaturedEvent() {
    const featuredEl = document.querySelector<HTMLElement>("[data-featured-event]");
    const noEventsEl = document.querySelector<HTMLElement>("[data-no-events]");
    if (!featuredEl) return;

    const today = new Date().toISOString().slice(0, 10);
    const { data, error } = await supabase
      .from("eventos")
      .select("artista, genero, fecha, hora, descripcion, imagen_url")
      .gte("fecha", today)
      .order("fecha", { ascending: true })
      .order("hora", { ascending: true })
      .limit(1);

    if (error || !data || data.length === 0) return;

    const ev = data[0] as Evento;

    const img = featuredEl.querySelector<HTMLImageElement>("[data-featured-image]");
    if (img && ev.imagen_url) {
      img.src = ev.imagen_url;
      img.alt = ev.artista;
    }
    const artistaEl = featuredEl.querySelector("[data-featured-artist]");
    if (artistaEl) artistaEl.textContent = ev.artista;
    const metaEl = featuredEl.querySelector("[data-featured-meta]");
    if (metaEl) {
      const genero = ev.genero ?? ev.descripcion;
      const fechaHora = `${formatFecha(ev.fecha)} · ${ev.hora.slice(0, 5)} hrs`;
      metaEl.textContent = genero ? `${genero} · ${fechaHora}` : fechaHora;
    }

    if (!ev.imagen_url) {
      featuredEl.querySelector<HTMLElement>("[data-featured-image]")?.parentElement?.classList.add("hidden");
    }

    featuredEl.classList.remove("hidden");
    noEventsEl?.classList.add("hidden");
  }

  loadFeaturedEvent();
</script>

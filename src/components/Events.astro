---
const events = [
  {
    image: '/Evento.jpg',
    date: 'Sáb 14 Jun',
    artist: 'Los Hermanos Bustamante',
    genre: 'Cumbia & Folclor',
    price: '$8.000',
    available: true,
  },
  {
    image: '/invitado.jpg',
    date: 'Sáb 21 Jun',
    artist: 'Valentina Morales',
    genre: 'Boleros & Baladas',
    price: '$10.000',
    available: true,
  },
  {
    image: '/fachada.webp',
    date: 'Vie 27 Jun',
    artist: 'Noche de Cueca',
    genre: 'Cueca tradicional',
    price: '$6.000',
    available: false,
  },
];

const waBase = 'https://wa.me/56974131205?text=Hola!%20Quiero%20reservar%20para%20el%20evento%20';
---

<section id="eventos" class="py-section-gap bg-surface-container-low">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4">
        Cartelera
      </span>
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface">
        Próximos eventos
      </h2>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {events.map((ev, i) => (
        <div
          class="reveal card-lift relative group rounded-xl overflow-hidden aspect-3/4 flex flex-col justify-end"
          style={`--reveal-delay: ${i * 120}ms`}
        >

          <!-- Imagen fondo -->
          <img
            src={ev.image}
            alt={ev.artist}
            class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
          />

          <!-- Gradiente -->
          <div class="absolute inset-0 bg-linear-to-t from-background via-background/60 to-transparent"></div>

          <!-- Contenido -->
          <div class="relative z-10 p-6">
            <!-- Fecha y género -->
            <div class="flex items-center justify-between mb-3">
              <span class="text-primary-container text-label-sm font-bold uppercase tracking-wider">{ev.date}</span>
              <span class="glass-card text-on-surface-variant text-xs px-2 py-1 rounded-full">{ev.genre}</span>
            </div>

            <!-- Artista -->
            <h3 class="font-headline-lg text-on-surface text-xl font-bold mb-4">{ev.artist}</h3>

            <!-- Precio + botón -->
            <div class="flex items-center justify-between">
              <div>
                <span class="text-on-surface-variant text-xs block">Entrada desde</span>
                <span class="text-on-surface font-bold text-lg">{ev.price}</span>
              </div>
              {ev.available ? (
                <a
                  href={`${waBase}${encodeURIComponent(ev.artist)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 px-4 py-2 bg-primary-container text-on-primary-container text-sm font-semibold rounded-full hover:opacity-90 transition-opacity"
                >
                  <span class="material-symbols-outlined text-base">confirmation_number</span>
                  Entradas
                </a>
              ) : (
                <span class="flex items-center gap-2 px-4 py-2 bg-surface-container text-on-surface-variant text-sm font-semibold rounded-full cursor-not-allowed">
                  Agotado
                </span>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA WhatsApp -->
    <div class="text-center mt-10">
      <a
        href="https://wa.me/56974131205?text=Hola!%20Quiero%20saber%20más%20sobre%20la%20cartelera%20de%20eventos"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary-container transition-colors text-sm"
      >
        <span class="material-symbols-outlined text-base">chat</span>
        Consultar por más fechas vía WhatsApp
      </a>
    </div>
  </div>
</section>

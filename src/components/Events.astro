---
// Todos los eventos con su flyer real, ordenados del más reciente al más antiguo.
// `iso` (yyyy-mm-dd) decide en qué bloque cae cada uno: futuro → "Próximo evento",
// pasado → "Últimos eventos". La lista se corta en build y se re-verifica en el
// navegador para que el sitio estático no quede congelado en la fecha del deploy.
const allEvents = [
  {
    image: "/erick-berrios.jpg",
    iso: "2026-07-15",
    date: "Mié 15 Jul",
    artist: "Erick Berríos",
    genre: "Tropical & Cumbia",
    time: "21:00",
  },
  {
    image: "/fiesta-a-la-chilena.jpg",
    iso: "2026-07-04",
    date: "Sáb 4 Jul",
    artist: "Fiesta a la Chilena",
    genre: "Los NN de la Cueca · Día del Cuequero",
    time: "20:00",
  },
  {
    image: "/pedroypablo.jpg",
    iso: "2026-06-29",
    date: "Lun 29 Jun",
    artist: "Celebración Pedro y Pablo",
    genre: "Música en vivo",
    time: "13:00",
  },
];

// Fecha local del build — NO usar toISOString (desfasa el día en Chile)
const now = new Date();
const pad = (n: number) => String(n).padStart(2, "0");
const todayIso = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}`;

const upcoming = allEvents
  .filter((ev) => ev.iso >= todayIso)
  .sort((a, b) => a.iso.localeCompare(b.iso));
const featured = upcoming[0] ?? null;
const past = allEvents.filter((ev) => ev.iso < todayIso);
---

<section
  id="eventos"
  class="py-section-gap bg-surface-container-low"
>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <!-- Header -->
    <div class="text-center mb-14">
      <span
        class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4"
      >
        Cartelera
      </span>
      <h2
        class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface"
      >
        Próximos eventos
      </h2>
    </div>

    <!-- Próximo evento: un único destacado -->
    {
      featured && (
        <div
          data-featured-event
          data-event-date={featured.iso}
          class="reveal card-lift group overflow-hidden bg-surface-container border border-primary-container/10 grid md:grid-cols-2 mb-20"
        >
          <div class="overflow-hidden">
            <img
              src={featured.image}
              alt={featured.artist}
              class="w-full h-auto transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <div class="p-6 md:p-10 flex flex-col justify-center">
            <span class="text-primary-container text-label-sm font-bold uppercase tracking-[0.3em] mb-4">
              Próximo evento
            </span>
            <h3 class="font-headline-lg text-on-surface text-3xl md:text-4xl font-bold mb-3">
              {featured.artist}
            </h3>
            <p class="text-on-surface-variant mb-6">{featured.genre}</p>
            <div class="flex items-center gap-6 mb-8 text-on-surface">
              <span class="inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-container">
                  calendar_month
                </span>
                {featured.date}
              </span>
              <span class="inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-primary-container">
                  schedule
                </span>
                {featured.time} hrs
              </span>
            </div>
            <a
              href="#reserva"
              class="btn-shine inline-block px-10 py-3 bg-primary-container text-on-primary-container text-sm font-bold tracking-widest uppercase text-center hover:brightness-110 active:scale-95 transition-all self-start"
            >
              Reservar
            </a>
          </div>
        </div>
      )
    }

    <!-- Estado sin eventos futuros -->
    <div
      data-no-events
      class={`${featured ? "hidden " : ""}reveal border border-primary-container/15 bg-surface-container text-center px-6 py-14 mb-20 max-w-2xl mx-auto`}
    >
      <span
        class="material-symbols-outlined text-primary-container text-4xl mb-4"
        >calendar_month</span
      >
      <h3
        class="font-headline-lg text-on-surface text-2xl md:text-3xl font-bold mb-3"
      >
        Estamos preparando la próxima fecha
      </h3>
      <p class="text-on-surface-variant mb-8 max-w-md mx-auto">
        Muy pronto anunciaremos un nuevo show en la terraza. Escríbenos por
        WhatsApp y te avisamos con anticipación.
      </p>
      <a
        href="https://wa.me/56966192139?text=Hola!%20Quiero%20saber%20cuándo%20es%20el%20próximo%20evento"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-shine inline-block px-10 py-3 bg-primary-container text-on-primary-container text-sm font-bold tracking-widest uppercase hover:brightness-110 active:scale-95 transition-all"
      >
        Avísame del próximo evento
      </a>
    </div>

    <!-- Últimos eventos -->
    <div class="text-center mb-10">
      <span
        class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4"
      >
        Así se vive la terraza
      </span>
      <h3
        class="font-headline-lg text-on-surface text-2xl md:text-3xl font-bold"
      >
        Últimos eventos
      </h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {
        past.map((ev, i) => (
          <div
            class="reveal card-lift group overflow-hidden bg-surface-container border border-primary-container/10 flex flex-col"
            style={`--reveal-delay: ${i * 100}ms`}
          >
            <div class="overflow-hidden">
              <img
                src={ev.image}
                alt={ev.artist}
                class="w-full h-auto transition-transform duration-700 group-hover:scale-105"
              />
            </div>
            <div class="p-5">
              <span class="text-primary-container text-label-sm font-bold uppercase tracking-wider block mb-1">
                {ev.date}
              </span>
              <h4 class="font-headline-lg text-on-surface text-lg font-bold">
                {ev.artist}
              </h4>
              <p class="text-on-surface-variant text-sm mt-1">{ev.genre}</p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- CTA WhatsApp -->
    <div class="text-center mt-10">
      <a
        href="https://wa.me/56966192139?text=Hola!%20Quiero%20saber%20más%20sobre%20la%20cartelera%20de%20eventos"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary-container transition-colors text-sm"
      >
        <span class="material-symbols-outlined text-base">chat</span>
        Consultar por más fechas vía WhatsApp
      </a>
    </div>
  </div>
</section>

<script>
  // Re-verifica en el navegador que el evento destacado siga siendo futuro:
  // si la fecha ya pasó (deploy antiguo), se oculta y se muestra el estado vacío.
  const featuredEl = document.querySelector<HTMLElement>(
    "[data-featured-event]",
  );
  if (featuredEl) {
    const iso = featuredEl.dataset.eventDate ?? "";
    const now = new Date();
    const pad = (n: number) => String(n).padStart(2, "0");
    const todayIso = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}`;
    if (iso < todayIso) {
      featuredEl.remove();
      document.querySelector("[data-no-events]")?.classList.remove("hidden");
    }
  }
</script>

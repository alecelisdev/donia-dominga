---
import SocialIcon from "./SocialIcon.astro";

const year = new Date().getFullYear();

const socials = [
  {
    platform: "instagram" as const,
    label: "Instagram",
    href: "https://www.instagram.com/domingamallarauco_piri/",
  },
  {
    platform: "facebook" as const,
    label: "Facebook",
    href: "https://facebook.com",
  },
  {
    platform: "whatsapp" as const,
    label: "WhatsApp",
    href: "https://wa.me/56974131205",
  },
];

const mapsLink = {
  icon: "map",
  label: "Google Maps",
  href: "https://www.google.com/maps/dir/?api=1&destination=Terraza%20Do%C3%B1a%20Dominga%2C%20Santa%20Victoria%20de%20Mallarauco%20121%2C%20Melipilla%2C%20Regi%C3%B3n%20Metropolitana",
};
---

<footer
  class="bg-surface-container-lowest border-t border-primary-container/10 py-12"
>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <div
      class="flex flex-col md:flex-row items-center md:items-start justify-between gap-8"
    >
      <!-- Marca -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <div class="flex items-center gap-3">
          <img
            src="/Logo.jpg"
            alt="Logo Doña Dominga"
            class="h-10 w-10 object-cover"
          />
          <span class="font-headline-lg text-on-surface text-lg font-semibold"
            >Doña Dominga</span
          >
        </div>
        <p
          class="text-on-surface-variant text-xs text-center md:text-left max-w-xs leading-relaxed"
        >
          Terraza con shows en vivo en Mallarauco, Región Metropolitana.
          Gastronomía artesanal y buena onda.
        </p>
        <p class="text-on-surface-variant/40 text-xs">
          © {year} Terraza Doña Dominga. Todos los derechos reservados.
        </p>
      </div>

      <!-- Links rápidos -->
      <div class="flex flex-col items-center md:items-start gap-2 text-sm">
        <span
          class="text-on-surface-variant/60 text-xs uppercase tracking-wider font-semibold mb-1"
          >Navegación</span
        >
        <a
          href="#nosotros"
          class="text-on-surface-variant hover:text-primary-container transition-colors"
          >Nosotros</a
        >
        <a
          href="#eventos"
          class="text-on-surface-variant hover:text-primary-container transition-colors"
          >Eventos</a
        >
        <a
          href="#menu"
          class="text-on-surface-variant hover:text-primary-container transition-colors"
          >Menú</a
        >
        <a
          href="#reserva"
          class="text-on-surface-variant hover:text-primary-container transition-colors"
          >Reservas</a
        >
        <a
          href="#contacto"
          class="text-on-surface-variant hover:text-primary-container transition-colors"
          >Contacto</a
        >
      </div>

      <!-- Redes sociales -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <span
          class="text-on-surface-variant/60 text-xs uppercase tracking-wider font-semibold"
          >Síguenos</span
        >
        <div class="flex gap-3">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="w-10 h-10 glass-card flex items-center justify-center text-on-surface-variant hover:text-primary-container hover:border-primary-container/30 transition-all"
              >
                <SocialIcon
                  platform={s.platform}
                  class="w-[18px] h-[18px]"
                />
              </a>
            ))
          }
          <a
            href={mapsLink.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={mapsLink.label}
            class="w-10 h-10 glass-card flex items-center justify-center text-on-surface-variant hover:text-primary-container hover:border-primary-container/30 transition-all"
          >
            <span class="material-symbols-outlined text-lg"
              >{mapsLink.icon}</span
            >
          </a>
        </div>
        <a
          href="tel:+56974131205"
          class="text-on-surface-variant hover:text-primary-container transition-colors text-sm flex items-center gap-1.5"
        >
          <span class="material-symbols-outlined text-sm">phone</span>
          +56 9 7413 1205
        </a>
      </div>
    </div>

    <!-- Firma -->
    <div class="mt-10 pt-6 border-t border-primary-container/10 text-center">
      <p
        class="text-on-surface-variant/40 text-sm flex items-center justify-center gap-1.5"
      >
        Desarrollado por
        <a
          href="https://www.alecelis.cl/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-primary-container/80 hover:text-primary-container transition-colors"
        >
          <img
            src="/ac-logo.svg"
            alt=""
            class="w-4 h-4"
          />
          <span class="underline-offset-2">Ale Celis</span>
        </a>
      </p>
    </div>
  </div>
</footer>

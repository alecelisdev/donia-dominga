---
import { Image } from "astro:assets";
import SocialIcon from "./SocialIcon.astro";

// El Local
import fachadaImg from "../assets/gallery/local/fachada.webp";
import localImg from "../assets/gallery/local/local.webp";
import local18Img from "../assets/gallery/local/local-18.jpg";
import terrazaLocalImg from "../assets/gallery/local/terraza.webp";
import terraza2Img from "../assets/gallery/local/terraza2.webp";
import local2180Img from "../assets/gallery/local/IMG_2180.jpeg";

// Nuestra Mesa
import carneImg from "../assets/gallery/nuestra-mesa/carne.jpg";
import polloImg from "../assets/gallery/nuestra-mesa/pollo.jpg";
import pastelChocloImg from "../assets/gallery/nuestra-mesa/pastel-de-choclo.jpg";
import porotosImg from "../assets/gallery/nuestra-mesa/porotos.jpg";
import sopaipillasImg from "../assets/gallery/nuestra-mesa/sopaipillas.jpg";
import tortaImg from "../assets/gallery/nuestra-mesa/torta.jpg";

// Shows
import folclorImg from "../assets/gallery/show/folclor.jpg";
import pabloHerreraImg from "../assets/gallery/show/pablo-herrera.jpg";
import pamelaLeivaImg from "../assets/gallery/show/pamela-leiva.jpg";
import pamelaLeiva2Img from "../assets/gallery/show/pamela-leiva2.jpg";
import salonShowImg from "../assets/gallery/show/salon-show.jpg";
import melonMelameImg from "../assets/gallery/show/show-melon-y-melame.jpg";

const tabs = ["El Local", "Nuestra Mesa", "Shows"];

// 6 fotos reales por tab: 3 col x 2 filas en desktop, 2 col x 3 filas en mobile
const images = {
  "El Local": [
    { src: fachadaImg, alt: "Fachada de Terraza Doña Dominga" },
    { src: terrazaLocalImg, alt: "La terraza de noche" },
    { src: localImg, alt: "El salón principal del local" },
    { src: terraza2Img, alt: "Vista de la terraza iluminada" },
    { src: local18Img, alt: "Ambiente interior de Doña Dominga" },
    { src: local2180Img, alt: "Un rincón de la terraza" },
  ],
  "Nuestra Mesa": [
    { src: carneImg, alt: "Corte de carne a la parrilla" },
    { src: polloImg, alt: "Plato de pollo de la casa" },
    { src: pastelChocloImg, alt: "Pastel de choclo casero" },
    { src: porotosImg, alt: "Porotos granados a la chilena" },
    { src: sopaipillasImg, alt: "Sopaipillas caseras" },
    { src: tortaImg, alt: "Torta de la casa" },
  ],
  Shows: [
    { src: folclorImg, alt: "Show de folclor en vivo" },
    { src: pabloHerreraImg, alt: "Pablo Herrera en vivo en Doña Dominga" },
    { src: pamelaLeivaImg, alt: "Pamela Leiva en el escenario" },
    { src: pamelaLeiva2Img, alt: "Pamela Leiva durante su show" },
    { src: salonShowImg, alt: "El salón lleno durante un show en vivo" },
    { src: melonMelameImg, alt: "Show de Melón y Melame en la terraza" },
  ],
};
---

<section
  id="galeria"
  class="py-section-gap bg-background border-t border-primary-container/10"
>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <!-- Header -->
    <div class="text-center mb-10">
      <span
        class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4"
      >
        Galería
      </span>
      <h2
        class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface"
      >
        Una imagen vale más que mil palabras
      </h2>
    </div>

    <!-- Tabs -->
    <div
      class="flex justify-center gap-2 mb-10 flex-wrap"
      id="gallery-tabs"
    >
      {
        tabs.map((tab, i) => (
          <button
            data-tab={tab}
            class={`gallery-tab px-5 py-2.5 text-sm font-semibold transition-all ${i === 0 ? "bg-primary-container text-on-primary-container" : "bg-surface-container text-on-surface-variant hover:text-on-surface border border-outline-variant/30"}`}
          >
            {tab}
          </button>
        ))
      }
    </div>

    <!-- Grid -->
    {
      tabs.map((tab) => (
        <div
          id={`gallery-panel-${tab.replace(/\s+/g, "-").toLowerCase()}`}
          class={`gallery-panel grid grid-cols-2 lg:grid-cols-3 gap-4 ${tab !== tabs[0] ? "hidden" : ""}`}
          data-panel={tab}
        >
          {images[tab as keyof typeof images].map((img) => (
            <div class="card-lift aspect-square overflow-hidden bg-surface-container group">
              <Image
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-110"
              />
            </div>
          ))}
        </div>
      ))
    }

    <!-- CTA Instagram -->
    <div
      class="glass-card mt-8 p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-5 text-center md:text-left"
    >
      <div class="flex items-center gap-4">
        <div>
          <h3 class="font-headline-lg text-on-surface font-semibold text-lg">
            ¿Quieres ver más?
          </h3>
          <p class="text-on-surface-variant text-sm">
            Síguenos en Instagram y descubre más fotos de la terraza, los platos
            y los shows en vivo.
          </p>
        </div>
      </div>
      <a
        href="https://www.instagram.com/domingamallarauco_piri/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-shine inline-flex items-center gap-2 px-8 py-3 bg-primary-container text-on-primary-container text-sm font-bold tracking-widest uppercase hover:brightness-110 active:scale-95 transition-all shrink-0"
      >
        <SocialIcon
          platform="instagram"
          class="w-4 h-4"
        />
        Ver Instagram
      </a>
    </div>
  </div>
</section>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".gallery-tab");
  const panels = document.querySelectorAll<HTMLElement>(".gallery-panel");

  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.tab;

      tabBtns.forEach((b) => {
        b.classList.remove("bg-primary-container", "text-on-primary-container");
        b.classList.add(
          "bg-surface-container",
          "text-on-surface-variant",
          "border",
          "border-outline-variant/30",
        );
      });
      btn.classList.add("bg-primary-container", "text-on-primary-container");
      btn.classList.remove(
        "bg-surface-container",
        "text-on-surface-variant",
        "border",
        "border-outline-variant/30",
      );

      panels.forEach((panel) => {
        panel.classList.toggle("hidden", panel.dataset.panel !== target);
      });
    });
  });
</script>

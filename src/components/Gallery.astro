---
const tabs = ['El Local', 'Nuestra Mesa', 'Momentos y Shows'];

const images = {
  'El Local': [
    { src: '/fachada.webp', alt: 'Fachada de Terraza Doña Dominga' },
    { src: '/Terraza.webp', alt: 'Vista de la terraza de noche' },
    { src: '/Portada%20fb.jpg', alt: 'Portada del local' },
  ],
  'Nuestra Mesa': [
    { src: '/Familia.jpg', alt: 'Familia disfrutando en Doña Dominga' },
    { src: '/fachada.webp', alt: 'Mesa con productos artesanales' },
    { src: '/Terraza.webp', alt: 'Terraza lista para la noche' },
  ],
  'Momentos y Shows': [
    { src: '/Evento.jpg', alt: 'Show en vivo en la terraza' },
    { src: '/invitado.jpg', alt: 'Artista invitado en Doña Dominga' },
    { src: '/Portada%20fb.jpg', alt: 'Noche de música y gastronomía' },
  ],
};
---

<section id="galeria" class="py-section-gap bg-surface-container-low">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">

    <!-- Header -->
    <div class="text-center mb-10">
      <span class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4">
        Galería
      </span>
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface">
        Una imagen vale más que mil palabras
      </h2>
    </div>

    <!-- Tabs -->
    <div class="flex justify-center gap-2 mb-10 flex-wrap" id="gallery-tabs">
      {tabs.map((tab, i) => (
        <button
          data-tab={tab}
          class={`gallery-tab px-5 py-2.5 rounded-full text-sm font-semibold transition-all ${i === 0 ? 'bg-primary-container text-on-primary-container' : 'bg-surface-container text-on-surface-variant hover:text-on-surface border border-outline-variant/30'}`}
        >
          {tab}
        </button>
      ))}
    </div>

    <!-- Grid -->
    {tabs.map((tab) => (
      <div
        id={`gallery-panel-${tab.replace(/\s+/g, '-').toLowerCase()}`}
        class={`gallery-panel grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 ${tab !== tabs[0] ? 'hidden' : ''}`}
        data-panel={tab}
      >
        {images[tab as keyof typeof images].map((img) => (
          <div class="card-lift aspect-square overflow-hidden rounded-xl bg-surface-container group">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-110"
            />
          </div>
        ))}
      </div>
    ))}
  </div>
</section>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.gallery-tab');
  const panels = document.querySelectorAll<HTMLElement>('.gallery-panel');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;

      tabBtns.forEach(b => {
        b.classList.remove('bg-primary-container', 'text-on-primary-container');
        b.classList.add('bg-surface-container', 'text-on-surface-variant', 'border', 'border-outline-variant/30');
      });
      btn.classList.add('bg-primary-container', 'text-on-primary-container');
      btn.classList.remove('bg-surface-container', 'text-on-surface-variant', 'border', 'border-outline-variant/30');

      panels.forEach(panel => {
        panel.classList.toggle('hidden', panel.dataset.panel !== target);
      });
    });
  });
</script>

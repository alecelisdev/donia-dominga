---
import { Image } from "astro:assets";
import terrazaImg from "../assets/hero/terraza.webp";
---

<section
  id="inicio"
  class="relative w-full min-h-screen flex md:items-center items-end"
>
  <!-- Background image (parallax wrapper) -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute inset-0 hero-kenburns-wrapper">
      <Image
        id="parallax-bg"
        src={terrazaImg}
        alt="Terraza Doña Dominga de noche"
        class="hero-bg-treated absolute left-0 right-0 w-full object-cover object-center will-change-transform"
        style="height: 115%; top: -7.5%"
      />
    </div>
  </div>

  <!-- Overlay -->
  <div class="hero-overlay absolute inset-0"></div>

  <!-- Content -->
  <div
    class="relative z-10 w-full max-w-container-max mx-auto px-margin-mobile md:px-gutter pb-16 md:pb-0"
  >
    <div class="max-w-2xl hero-content-glow">
      <!-- Logo -->
      <img
        src="/Logo.jpg"
        alt="Logo Terraza Doña Dominga"
        class="hero-animate h-24 w-24 md:h-36 md:w-36 object-cover mb-6 md:mb-8 border-2 border-primary-container/30 box-glow"
        style="animation-delay: 0.05s"
      />

      <!-- Título -->
      <div
        class="hero-animate font-headline-lg leading-none mb-5"
        style="animation-delay: 0.35s"
      >
        <p
          class="block text-on-surface/90 font-semibold text-2xl md:text-4xl tracking-wide mb-2 md:mb-3"
        >
          Bienvenidos a
        </p>
        <h1
          class="block font-extrabold tracking-tight text-6xl md:text-8xl text-gradient-warm text-glow-strong"
          style="padding-bottom: 0.15em; margin-bottom: -0.15em"
        >
          Terraza <br />Doña Dominga
        </h1>
      </div>

      <p
        class="hero-animate text-on-surface-variant text-body-lg mb-8 max-w-sm leading-relaxed"
        style="animation-delay: 0.5s"
      >
        Comida casera, buena música y la mejor compañía, en el corazón de
        Mallarauco.
      </p>

      <!-- CTAs -->
      <div
        class="hero-animate flex flex-col sm:flex-row gap-stack-md"
        style="animation-delay: 0.65s"
      >
        <a
          href="#reserva"
          class="btn-shine inline-flex items-center justify-center px-10 py-4 bg-primary-container text-on-primary-container text-sm font-bold tracking-[0.2em] uppercase hover:brightness-110 active:scale-[0.98] transition-all"
        >
          Reservar Mesa
        </a>
        <a
          href="#eventos"
          class="btn-shine inline-flex items-center justify-center px-10 py-4 border border-primary-container text-primary-container text-sm font-bold tracking-[0.2em] uppercase hover:bg-primary-container/10 active:scale-[0.98] transition-all"
        >
          Ver Eventos
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-on-surface-variant/50 animate-bounce"
  >
    <span class="material-symbols-outlined text-xl">keyboard_arrow_down</span>
  </div>
</section>

<script>
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const bg = document.getElementById("parallax-bg") as HTMLElement | null;
    const section = document.getElementById("inicio") as HTMLElement | null;

    if (bg && section) {
      let rafQueued = false;

      window.addEventListener(
        "scroll",
        () => {
          if (rafQueued) return;
          rafQueued = true;
          requestAnimationFrame(() => {
            if (section.getBoundingClientRect().bottom > 0) {
              bg.style.transform = `translateY(${window.scrollY * 0.28}px)`;
            }
            rafQueued = false;
          });
        },
        { passive: true },
      );
    }
  }
</script>

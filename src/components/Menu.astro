---
import { getMenuItem } from "../data/menu";

// TODO: reemplazar los placeholders por fotos reales de cada plato cuando estén disponibles.
const dishes = [
  { id: "corte-parrilla", big: true },
  { id: "filete-pollo-grilla" },
  { id: "mojito-tradicional" },
];
---

<section
  id="menu"
  class="py-20 md:py-section-gap bg-background border-t border-primary-container/10 md:border-t-0"
>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <!-- Header -->
    <div class="text-center mb-16">
      <span
        class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4"
      >
        Gastronomía
      </span>
      <h2
        class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-6"
      >
        Nuestra Carta
      </h2>
      <p
        class="text-on-surface-variant text-body-md max-w-2xl mx-auto leading-relaxed"
      >
        Una selección curada que celebra los ingredientes locales de Mallarauco.
        Sabores tradicionales diseñados para acompañar nuestras noches de show.
      </p>
    </div>

    <!-- Subtítulo: recomendaciones de la casa -->
    <p
      class="text-center text-primary-container text-sm md:text-base font-semibold uppercase tracking-[0.2em] mb-8"
    >
      Recomendaciones de la Casa
    </p>

    <!-- Platos recomendados: 1 card grande + 2 chicas (fotos placeholder por ahora) -->
    <div class="flex flex-col md:flex-row md:items-start gap-3 md:gap-4 mb-14">
      {
        dishes.map((dish, i) => {
          const item = getMenuItem(dish.id);
          return (
            <div
              class={`card-lift reveal relative overflow-hidden group aspect-4/3 bg-surface-container-high border border-dashed border-primary-container/20 ${
                dish.big
                  ? "md:flex-[1.4_1_0%] md:aspect-square"
                  : "md:flex-1 md:aspect-square"
              }`}
              style={`--reveal-delay: ${i * 130}ms`}
            >
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="material-symbols-outlined text-on-surface-variant/25 text-6xl md:text-7xl">
                  restaurant
                </span>
              </div>
              <div class="absolute inset-0 bg-linear-to-t from-background/90 via-background/10 to-transparent" />
              <div class="absolute bottom-4 left-4 right-4 md:bottom-5 md:left-5 md:right-5">
                <h3 class="font-headline-lg text-on-surface text-lg md:text-xl leading-tight">
                  {item.name}
                </h3>
              </div>
            </div>
          );
        })
      }
    </div>

    <!-- CTA: ver las 3 cartas -->
    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4"
    >
      <a
        href="/carta-cafeteria.html"
        target="_blank"
        rel="noopener"
        class="min-h-11 w-full sm:w-auto inline-flex items-center justify-center gap-2 px-10 py-4 border border-primary-container text-primary-container hover:bg-primary-container/10 transition-all font-bold uppercase text-sm tracking-widest"
      >
        <span class="material-symbols-outlined text-xl">local_cafe</span>
        Ver Carta Cafetería
      </a>
      <a
        href="/carta-restaurant.html"
        target="_blank"
        rel="noopener"
        class="btn-shine relative overflow-hidden min-h-11 w-full sm:w-auto inline-flex items-center justify-center gap-2 px-10 py-4 bg-primary-container text-on-primary-container hover:bg-primary-container/90 transition-all font-bold uppercase text-sm tracking-widest"
      >
        <span class="material-symbols-outlined text-xl">restaurant_menu</span>
        Ver Carta Restaurant
      </a>
      <a
        href="/carta-eventos.html"
        target="_blank"
        rel="noopener"
        class="min-h-11 w-full sm:w-auto inline-flex items-center justify-center gap-2 px-10 py-4 border border-primary-container text-primary-container hover:bg-primary-container/10 transition-all font-bold uppercase text-sm tracking-widest"
      >
        <span class="material-symbols-outlined text-xl">celebration</span>
        Ver Carta Eventos
      </a>
    </div>
    <p class="mt-5 text-center text-on-surface-variant text-xs italic">
      La coctelería y los vinos están incluidos en la Carta Restaurant.
    </p>
  </div>
</section>

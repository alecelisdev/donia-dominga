---

<section id="menu" class="py-section-gap bg-background">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">

    <!-- Header -->
    <div class="text-center mb-16">
      <span class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4">
        Gastronomía
      </span>
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-6">
        Nuestra Carta
      </h2>
      <p class="text-on-surface-variant text-body-md max-w-2xl mx-auto leading-relaxed">
        Una selección curada que celebra los ingredientes locales de Mallarauco. Sabores tradicionales diseñados para acompañar nuestras noches de show.
      </p>
    </div>

    <!-- Tabs: sticky bajo el nav (h-16) para poder cambiar de categoría sin volver a subir -->
    <div class="sticky top-16 z-40 bg-background/95 backdrop-blur-md py-4 -mx-margin-mobile px-margin-mobile md:mx-0 md:px-0 flex flex-wrap justify-center gap-4 mb-12">
      {tabs.map((tab, i) => (
        <button
          data-menu-tab={tab.id}
          class={`menu-tab min-h-11 inline-flex items-center justify-center px-8 py-3 border border-outline-variant text-on-surface-variant font-bold uppercase text-sm tracking-widest transition-all hover:border-primary-container hover:text-primary-container ${i === 0 ? 'is-active' : ''}`}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <!-- Bento por tab -->
    {tabs.map((tab, i) => (
      <div
        data-menu-panel={tab.id}
        class={`menu-panel grid grid-cols-2 md:grid-cols-4 md:grid-rows-2 gap-3 md:gap-6 md:h-150 ${i !== 0 ? 'hidden' : ''}`}
      >
        <!-- Card destacada -->
        <div class="card-lift col-span-2 md:row-span-2 relative group overflow-hidden rounded-xl h-48 md:h-auto">
          <img
            src={tab.featured.img}
            alt={tab.featured.name}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-linear-to-t from-background/90 via-transparent to-transparent"></div>
          <div class="absolute top-4 left-4 bg-primary-container text-on-primary-container text-[10px] font-bold uppercase tracking-widest px-3 py-1">
            Más Pedido
          </div>
          <div class="absolute bottom-4 left-4 right-4 md:bottom-6 md:left-6 md:right-6 flex justify-between items-end gap-4">
            <div>
              <h3 class="font-headline-lg text-on-surface text-xl md:text-2xl">{tab.featured.name}</h3>
              <p class="text-on-surface-variant text-sm">{tab.featured.desc}</p>
            </div>
            <span class="text-primary-container font-bold text-lg md:text-xl shrink-0">{tab.featured.price}</span>
          </div>
        </div>

        <!-- Cards secundarias -->
        {tab.items.map((item) => (
          <div class="card-lift md:col-span-2 relative group overflow-hidden rounded-xl aspect-square md:aspect-auto">
            <img
              src={item.img}
              alt={item.name}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-linear-to-t from-background/80 to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4 flex justify-between items-end gap-2">
              <h4 class="font-headline-lg text-on-surface text-base md:text-lg">{item.name}</h4>
              <span class="text-primary-container font-bold text-base md:text-lg shrink-0">{item.price}</span>
            </div>
          </div>
        ))}
      </div>
    ))}

    <!-- Happy Hour: caja rectangular, sin glass-card -->
    <div class="mt-12 p-8 border border-primary-container/20 bg-surface-container-low flex flex-col md:flex-row items-center justify-center gap-6 text-center md:text-left">
      <div class="w-12 h-12 bg-primary-container/10 rounded-full flex items-center justify-center shrink-0">
        <span class="material-symbols-outlined text-primary-container text-3xl">local_bar</span>
      </div>
      <div>
        <h4 class="text-xl font-bold text-on-surface mb-1">Happy Hour</h4>
        <p class="text-on-surface-variant text-body-md">
          Jueves y Viernes de 18:00 a 20:00. <span class="text-primary-container font-bold">2x1 en Coctelería Nacional</span>.
        </p>
      </div>
    </div>

    <!-- Carta completa expandible -->
    <div class="mt-16 text-center">
      <button
        id="toggle-menu-btn"
        data-label-closed="Ver carta completa"
        data-label-open="Ver menos"
        class="min-h-11 inline-flex items-center justify-center px-12 py-4 border border-primary-container text-primary-container hover:bg-primary-container/10 transition-all font-bold uppercase text-sm tracking-widest"
      >
        Ver carta completa
      </button>
    </div>

    <div id="full-menu" class="hidden mt-16 max-w-3xl mx-auto">
      {tabs.map((tab, i) => (
        <div
          data-fullmenu-panel={tab.id}
          class={`space-y-3 ${i !== 0 ? 'hidden' : ''}`}
        >
          {fullMenus[tab.id].groups.map((group, gi) => (
            <details
              class="group border border-primary-container/15 bg-surface-container-low"
              name={`accordion-${tab.id}`}
              open={gi === 0}
            >
              <summary class="min-h-11 flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none font-bold text-on-surface uppercase text-sm tracking-widest">
                <span>{group.name}</span>
                <span class="material-symbols-outlined text-primary-container transition-transform duration-300 group-open:rotate-180 shrink-0">
                  expand_more
                </span>
              </summary>
              <div class="px-5 pb-5 border-t border-primary-container/10">
                {group.note && (
                  <p class="text-on-surface-variant text-xs italic pt-4">{group.note}</p>
                )}
                <ul class="divide-y divide-primary-container/10">
                  {group.items.map((item) => (
                    <li class="flex items-center justify-between gap-4 py-3.5">
                      <span class="text-on-surface text-sm md:text-base">{item.name}</span>
                      <span class="text-primary-container font-bold text-sm md:text-base shrink-0">{item.price}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </details>
          ))}
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* Estado activo definido en CSS puro — no togglear clases Tailwind desde JS */
  .menu-tab.is-active {
    background-color: var(--color-primary-container);
    border-color: var(--color-primary-container);
    color: var(--color-on-primary-container);
  }
</style>

<script>
  const menuTabs = document.querySelectorAll<HTMLButtonElement>('.menu-tab');
  const menuPanels = document.querySelectorAll<HTMLElement>('.menu-panel');
  const fullMenuPanels = document.querySelectorAll<HTMLElement>('[data-fullmenu-panel]');
  const toggleBtn = document.getElementById('toggle-menu-btn');
  const fullMenuEl = document.getElementById('full-menu');

  const setToggleLabel = () => {
    if (!toggleBtn) return;
    const isOpen = !fullMenuEl?.classList.contains('hidden');
    toggleBtn.textContent = isOpen
      ? (toggleBtn.dataset.labelOpen ?? 'Ver menos')
      : (toggleBtn.dataset.labelClosed ?? 'Ver carta completa');
  };

  menuTabs.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.menuTab;
      menuTabs.forEach((b) => b.classList.toggle('is-active', b === btn));
      menuPanels.forEach((panel) => {
        panel.classList.toggle('hidden', panel.dataset.menuPanel !== target);
      });
      fullMenuPanels.forEach((panel) => {
        panel.classList.toggle('hidden', panel.dataset.fullmenuPanel !== target);
      });
    });
  });

  toggleBtn?.addEventListener('click', () => {
    fullMenuEl?.classList.toggle('hidden');
    setToggleLabel();
  });
</script>

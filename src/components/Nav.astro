---
import SocialIcon from "./SocialIcon.astro";
---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-primary-container/20 transition-all duration-300"
>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href="#inicio"
        class="flex items-center gap-3"
      >
        <img
          src="/Logo.jpg"
          alt="Doña Dominga"
          class="h-10 w-10 object-cover"
        />
        <span
          class="font-headline-lg text-on-surface text-lg font-semibold hidden sm:block"
          >Doña Dominga</span
        >
      </a>

      <!-- Links desktop -->
      <div
        id="nav-links-desktop"
        class="hidden md:flex items-center gap-8 relative"
      >
        <a
          href="#eventos"
          data-nav-link="eventos"
          class="nav-link text-on-surface-variant hover:text-on-surface text-sm font-medium transition-all duration-300"
          >Eventos</a
        >
        <a
          href="#menu"
          data-nav-link="menu"
          class="nav-link text-on-surface-variant hover:text-on-surface text-sm font-medium transition-all duration-300"
          >Menú</a
        >
        <a
          href="#galeria"
          data-nav-link="galeria"
          class="nav-link text-on-surface-variant hover:text-on-surface text-sm font-medium transition-all duration-300"
          >Galería</a
        >
        <a
          href="#nosotros"
          data-nav-link="nosotros"
          class="nav-link text-on-surface-variant hover:text-on-surface text-sm font-medium transition-all duration-300"
          >Nosotros</a
        >
        <a
          href="#contacto"
          data-nav-link="contacto"
          class="nav-link text-on-surface-variant hover:text-on-surface text-sm font-medium transition-all duration-300"
          >Contacto</a
        >
        <!-- Indicador activo deslizante -->
        <span
          id="nav-indicator"
          class="nav-indicator"
          aria-hidden="true"
        ></span>
      </div>

      <!-- Redes sociales desktop -->
      <div class="hidden md:flex items-center gap-4">
        <a
          href="https://www.instagram.com/domingamallarauco_piri/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="text-on-surface-variant hover:text-primary-container transition-colors duration-300"
        >
          <SocialIcon
            platform="instagram"
            class="w-5 h-5"
          />
        </a>
        <a
          href="https://facebook.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="text-on-surface-variant hover:text-primary-container transition-colors duration-300"
        >
          <SocialIcon
            platform="facebook"
            class="w-5 h-5"
          />
        </a>
      </div>

      <!-- CTA + hamburger -->
      <div class="flex items-center gap-3">
        <a
          href="#reserva"
          class="hidden md:inline-flex items-center px-6 py-2 bg-primary-container text-on-primary-container text-xs font-bold tracking-widest uppercase hover:brightness-110 active:scale-95 transition-all"
        >
          Reservar
        </a>

        <button
          id="mobile-menu-btn"
          class="md:hidden flex flex-col gap-1.5 p-2 text-on-surface"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <span
            class="block w-6 h-0.5 bg-current transition-all duration-300"
            id="bar1"
          ></span>
          <span
            class="block w-6 h-0.5 bg-current transition-all duration-300"
            id="bar2"
          ></span>
          <span
            class="block w-4 h-0.5 bg-current transition-all duration-300"
            id="bar3"
          ></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-surface-container-low border-t border-primary-container/10"
  >
    <div class="flex flex-col py-4 px-margin-mobile gap-1">
      <a
        href="#eventos"
        data-nav-link="eventos"
        class="nav-link mobile-link spark-indicator pl-4 py-3 text-on-surface-variant hover:text-on-surface font-medium transition-all duration-300"
        >Eventos</a
      >
      <a
        href="#menu"
        data-nav-link="menu"
        class="nav-link mobile-link spark-indicator pl-4 py-3 text-on-surface-variant hover:text-on-surface font-medium transition-all duration-300"
        >Menú</a
      >
      <a
        href="#galeria"
        data-nav-link="galeria"
        class="nav-link mobile-link spark-indicator pl-4 py-3 text-on-surface-variant hover:text-on-surface font-medium transition-all duration-300"
        >Galería</a
      >
      <a
        href="#nosotros"
        data-nav-link="nosotros"
        class="nav-link mobile-link spark-indicator pl-4 py-3 text-on-surface-variant hover:text-on-surface font-medium transition-all duration-300"
        >Nosotros</a
      >
      <a
        href="#contacto"
        data-nav-link="contacto"
        class="nav-link mobile-link spark-indicator pl-4 py-3 text-on-surface-variant hover:text-on-surface font-medium transition-all duration-300"
        >Contacto</a
      >
      <a
        href="#reserva"
        class="mt-3 flex items-center justify-center px-5 py-3 bg-primary-container text-on-primary-container text-xs font-bold tracking-widest uppercase mobile-link"
      >
        Reservar
      </a>

      <!-- Redes sociales mobile -->
      <div class="flex items-center justify-center gap-6 mt-5">
        <a
          href="https://www.instagram.com/domingamallarauco_piri/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="text-on-surface-variant hover:text-primary-container transition-colors duration-300"
        >
          <SocialIcon
            platform="instagram"
            class="w-6 h-6"
          />
        </a>
        <a
          href="https://facebook.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="text-on-surface-variant hover:text-primary-container transition-colors duration-300"
        >
          <SocialIcon
            platform="facebook"
            class="w-6 h-6"
          />
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  // ── Hamburger ──────────────────────────────────────────────────────────────
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const bar1 = document.getElementById("bar1");
  const bar3 = document.getElementById("bar3");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
    bar1?.classList.toggle("rotate-45", !isOpen);
    bar1?.classList.toggle("translate-y-2", !isOpen);
    bar3?.classList.toggle("opacity-0", !isOpen);
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
      bar1?.classList.remove("rotate-45", "translate-y-2");
      bar3?.classList.remove("opacity-0");
    });
  });

  // ── Sección activa en scroll ───────────────────────────────────────────────
  const navLinks =
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
  const sectionIds = [
    "nosotros",
    "eventos",
    "menu",
    "galeria",
    "contacto",
    "reserva",
  ];

  // Indicador deslizante (sólo desktop)
  const navIndicator = document.getElementById("nav-indicator");
  const desktopLinks = document.querySelectorAll<HTMLAnchorElement>(
    "#nav-links-desktop [data-nav-link]",
  );
  let activeId: string | null = null;

  function moveIndicator() {
    if (!navIndicator) return;
    const active = Array.from(desktopLinks).find(
      (l) => l.dataset.navLink === activeId,
    );
    if (!active) {
      navIndicator.style.opacity = "0";
      navIndicator.style.width = "0";
      return;
    }
    navIndicator.style.opacity = "1";
    navIndicator.style.width = `${active.offsetWidth}px`;
    navIndicator.style.transform = `translateX(${active.offsetLeft}px)`;
  }

  function setActive(id: string) {
    activeId = id;
    navLinks.forEach((link) => {
      const matches = link.dataset.navLink === id;
      link.classList.toggle("is-active", matches);
    });
    moveIndicator();
  }

  // Reposiciona el indicador si cambia el ancho de la ventana
  window.addEventListener("resize", moveIndicator, { passive: true });

  // rootMargin: sólo activa la sección que está en la banda 20%-60% del viewport
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    },
    { rootMargin: "-20% 0px -60% 0px", threshold: 0 },
  );

  sectionIds.forEach((id) => {
    const el = document.getElementById(id);
    if (el) sectionObserver.observe(el);
  });

  // Si el usuario vuelve al hero, desactivar todo
  const heroObserver = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        navLinks.forEach((l) => l.classList.remove("is-active"));
        activeId = null;
        moveIndicator();
      }
    },
    { rootMargin: "0px 0px -85% 0px", threshold: 0 },
  );
  const hero = document.getElementById("inicio");
  if (hero) heroObserver.observe(hero);
</script>

---
// Reseñas reales de Google Maps (4.8★ / 66 opiniones) — solo tienen texto corto,
// sin título/cuerpo separado como los placeholders anteriores.
const reviews = [
  {
    stars: 5,
    quote: 'Excelente lugar muy bien atendido y la comida exquisita',
  },
  {
    stars: 5,
    quote: 'Comida tradicional chilena, excelente relación precio calidad y atención familiar.',
  },
  {
    stars: 5,
    quote: 'El servicio muy amable y cordial. La comida estaba demasiado rica y la verdad muy satisfecho con la cantidad también. Incluso a precio bastante asequible.',
  },
  {
    stars: 5,
    quote: 'Excelente lugar, muy buena atención y la comida excelente. Lo mejor de la zona.',
  },
  {
    stars: 5,
    quote: 'Muy buen lugar para carretear y pasar un rato agradable',
  },
  {
    stars: 5,
    quote: 'Muy buenas empanadas de pino sabrosas y ricos helados artesanales',
  },
  {
    stars: 5,
    quote: 'Expedito y excelente lugar para almorzar con amigos o familiares',
  },
  {
    stars: 5,
    quote: 'El lugar muy bueno y la comida súper contundente!',
  },
];

// Carrusel infinito: se duplica el set para que el track pueda recorrer
// exactamente -50% de su ancho y volver a quedar idéntico (loop perfecto).
const track = [...reviews, ...reviews];
---

<section class="py-section-gap bg-surface-container-low">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="text-primary-container text-label-sm uppercase tracking-[0.3em] font-bold block mb-4">
        Opiniones
      </span>
      <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface">
        Lo que dicen nuestros clientes
      </h2>
    </div>

    <!-- Reviews: carrusel infinito -->
    <div class="testimonial-marquee">
      <div class="testimonial-track">
        {track.map((r, i) => (
          <div
            class={`px-6 py-8 flex flex-col min-h-44 w-80 md:w-96 shrink-0 border-primary-container/10 ${i === track.length - 1 ? '' : 'border-r'}`}
          >
            <!-- Estrellas -->
            <div class="flex gap-0.5 mb-3">
              {Array.from({ length: r.stars }).map(() => (
                <span class="material-symbols-outlined icon-filled text-primary-container text-base">star</span>
              ))}
            </div>

            <!-- Cita -->
            <p class="font-headline-lg text-on-surface italic font-semibold text-base leading-relaxed mb-4 flex-1">
              "{r.quote}"
            </p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

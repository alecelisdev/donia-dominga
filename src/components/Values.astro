---
const values = [
  {
    icon: 'eco',
    title: 'Productos del Campo',
    description: 'Ingredientes frescos y locales de Mallarauco.',
  },
  {
    icon: 'soup_kitchen',
    title: 'Comida Casera',
    description: 'Recetas tradicionales con el toque secreto de casa.',
  },
  {
    icon: 'groups',
    title: 'Atención Familiar',
    description: 'Te recibimos como en casa, con calidez y cercanía.',
  },
  {
    icon: 'history',
    title: 'Tradición 1993',
    description: 'Tres décadas de historia y momentos compartidos.',
  },
];
---

{/* Se renderiza dentro de la sección "nosotros" compartida con About (index.astro).
   El diseño Stitch v3 fusionado no lleva header propio: las cards siguen a la historia. */}
<div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">

    <!-- Grid de valores — sin bordes, sin glassmorphism -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {values.map((v, i) => (
        <div
          class="reveal text-center space-y-4 group"
          style={`--reveal-delay: ${i * 100}ms`}
        >
          <div class="w-16 h-16 mx-auto bg-primary-container/10 flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
            <span class="material-symbols-outlined text-primary-container text-3xl">{v.icon}</span>
          </div>
          <h3 class="text-xl font-bold text-on-surface">{v.title}</h3>
          <p class="text-sm text-on-surface-variant leading-relaxed">{v.description}</p>
        </div>
      ))}
    </div>

</div>

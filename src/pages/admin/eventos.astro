---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Eventos — Admin Doña Dominga" noindex={true}>
  <main class="min-h-screen px-4 py-8 max-w-2xl mx-auto space-y-8">
    <header class="flex items-center justify-between">
      <div>
        <h1 class="font-headline-lg text-2xl font-bold text-on-background">Eventos</h1>
        <p class="text-sm text-on-surface-variant">Panel Admin — Doña Dominga</p>
      </div>
      <div class="flex items-center gap-3 text-sm">
        <a href="/admin/carta-eventos" class="text-primary-container hover:underline">Carta de eventos →</a>
        <button
          id="logout-btn"
          type="button"
          class="text-on-surface-variant hover:text-on-surface border border-primary-container/20 px-3 py-1.5"
        >
          Salir
        </button>
      </div>
    </header>

    <section class="bg-surface-container-low border border-primary-container/20 p-5 space-y-4">
      <h2 class="font-headline-lg text-lg font-semibold text-on-surface" id="form-title">Nuevo evento</h2>
      <form id="evento-form" class="space-y-4">
        <input type="hidden" id="evento-id" name="id" />

        <div class="space-y-1">
          <label for="artista" class="text-xs uppercase tracking-wide text-on-surface-variant">Artista</label>
          <input id="artista" name="artista" type="text" required class="w-full bg-surface-container px-3 py-2.5 text-on-surface border border-primary-container/20 focus:border-primary-container focus:outline-none" />
        </div>

        <div class="space-y-1">
          <label for="genero" class="text-xs uppercase tracking-wide text-on-surface-variant">Género (opcional)</label>
          <input id="genero" name="genero" type="text" class="w-full bg-surface-container px-3 py-2.5 text-on-surface border border-primary-container/20 focus:border-primary-container focus:outline-none" />
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="space-y-1">
            <label for="fecha" class="text-xs uppercase tracking-wide text-on-surface-variant">Fecha</label>
            <input id="fecha" name="fecha" type="date" required class="w-full bg-surface-container px-3 py-2.5 text-on-surface border border-primary-container/20 focus:border-primary-container focus:outline-none" />
          </div>
          <div class="space-y-1">
            <label for="hora" class="text-xs uppercase tracking-wide text-on-surface-variant">Hora</label>
            <input id="hora" name="hora" type="time" required class="w-full bg-surface-container px-3 py-2.5 text-on-surface border border-primary-container/20 focus:border-primary-container focus:outline-none" />
          </div>
        </div>

        <div class="space-y-1">
          <label for="descripcion" class="text-xs uppercase tracking-wide text-on-surface-variant">Descripción (opcional)</label>
          <textarea id="descripcion" name="descripcion" rows="2" class="w-full bg-surface-container px-3 py-2.5 text-on-surface border border-primary-container/20 focus:border-primary-container focus:outline-none"></textarea>
        </div>

        <div class="space-y-1">
          <label for="imagen" class="text-xs uppercase tracking-wide text-on-surface-variant">Foto (opcional)</label>
          <input
            id="imagen"
            name="imagen"
            type="file"
            accept="image/*"
            capture="environment"
            class="w-full text-sm text-on-surface-variant cursor-pointer file:mr-3 file:cursor-pointer file:border-0 file:rounded-none file:bg-primary-container file:text-on-primary-container file:px-4 file:py-2 file:text-sm file:font-semibold file:hover:brightness-110 file:transition-all"
          />
          <img id="imagen-preview" class="hidden mt-2 max-h-40 border border-primary-container/20" />
        </div>

        <p id="form-error" class="hidden text-sm text-error"></p>
        <p id="form-status" class="hidden text-sm text-tertiary"></p>

        <div class="flex gap-3">
          <button type="submit" id="form-submit" class="bg-primary-container text-on-primary-container font-semibold px-5 py-2.5 hover:brightness-110 active:scale-95 transition-all disabled:opacity-50">
            Guardar
          </button>
          <button type="button" id="form-cancel" class="hidden text-on-surface-variant border border-primary-container/20 px-5 py-2.5 hover:bg-surface-container">
            Cancelar edición
          </button>
        </div>
      </form>
    </section>

    <section class="space-y-3">
      <h2 class="font-headline-lg text-lg font-semibold text-on-surface">Listado</h2>
      <div id="eventos-list" class="space-y-3">
        <p class="text-sm text-on-surface-variant">Cargando...</p>
      </div>
    </section>
  </main>
</Layout>

<script>
  import { supabase } from "../../lib/supabase";

  interface Evento {
    id: string;
    artista: string;
    genero: string | null;
    fecha: string;
    hora: string;
    descripcion: string | null;
    imagen_url: string | null;
  }

  const form = document.getElementById("evento-form") as HTMLFormElement | null;
  const formTitle = document.getElementById("form-title") as HTMLHeadingElement | null;
  const idInput = document.getElementById("evento-id") as HTMLInputElement | null;
  const artistaInput = document.getElementById("artista") as HTMLInputElement | null;
  const generoInput = document.getElementById("genero") as HTMLInputElement | null;
  const fechaInput = document.getElementById("fecha") as HTMLInputElement | null;
  const horaInput = document.getElementById("hora") as HTMLInputElement | null;
  const descripcionInput = document.getElementById("descripcion") as HTMLTextAreaElement | null;
  const imagenInput = document.getElementById("imagen") as HTMLInputElement | null;
  const imagenPreview = document.getElementById("imagen-preview") as HTMLImageElement | null;
  const errorEl = document.getElementById("form-error") as HTMLParagraphElement | null;
  const statusEl = document.getElementById("form-status") as HTMLParagraphElement | null;
  const submitBtn = document.getElementById("form-submit") as HTMLButtonElement | null;
  const cancelBtn = document.getElementById("form-cancel") as HTMLButtonElement | null;
  const listEl = document.getElementById("eventos-list") as HTMLDivElement | null;
  const logoutBtn = document.getElementById("logout-btn") as HTMLButtonElement | null;

  let currentImagenUrl: string | null = null;

  async function requireSession() {
    const { data } = await supabase.auth.getSession();
    if (!data.session) {
      window.location.href = "/admin";
    }
  }
  requireSession();

  logoutBtn?.addEventListener("click", async () => {
    await supabase.auth.signOut();
    window.location.href = "/admin";
  });

  function resetForm() {
    form?.reset();
    if (idInput) idInput.value = "";
    if (formTitle) formTitle.textContent = "Nuevo evento";
    cancelBtn?.classList.add("hidden");
    imagenPreview?.classList.add("hidden");
    currentImagenUrl = null;
    errorEl?.classList.add("hidden");
    statusEl?.classList.add("hidden");
  }

  cancelBtn?.addEventListener("click", resetForm);

  function showError(msg: string) {
    if (errorEl) {
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    }
  }

  function showStatus(msg: string) {
    if (statusEl) {
      statusEl.textContent = msg;
      statusEl.classList.remove("hidden");
    }
  }

  async function loadEventos() {
    if (!listEl) return;
    const { data, error } = await supabase
      .from("eventos")
      .select("*")
      .order("fecha", { ascending: true })
      .order("hora", { ascending: true });

    if (error) {
      listEl.innerHTML = `<p class="text-sm text-error">Error cargando eventos: ${error.message}</p>`;
      return;
    }

    const eventos = (data ?? []) as Evento[];
    if (eventos.length === 0) {
      listEl.innerHTML = `<p class="text-sm text-on-surface-variant">Sin eventos registrados.</p>`;
      return;
    }

    listEl.innerHTML = "";
    eventos.forEach((ev) => {
      const row = document.createElement("div");
      row.className = "flex items-center justify-between gap-3 bg-surface-container-low border border-primary-container/10 px-4 py-3";
      row.innerHTML = `
        <div class="flex items-center gap-3 min-w-0">
          ${ev.imagen_url ? `<img src="${ev.imagen_url}" class="w-12 h-12 object-cover border border-primary-container/20 shrink-0" />` : ""}
          <div class="min-w-0">
            <p class="text-on-surface font-semibold truncate">${ev.artista}</p>
            <p class="text-xs text-on-surface-variant">${ev.fecha} · ${ev.hora}${ev.genero ? " · " + ev.genero : ""}</p>
          </div>
        </div>
        <div class="flex gap-2 shrink-0">
          <button type="button" data-edit="${ev.id}" class="text-xs text-primary-container border border-primary-container/30 px-2.5 py-1.5 hover:bg-primary-container hover:text-on-primary-container transition-colors">Editar</button>
          <button type="button" data-delete="${ev.id}" class="text-xs text-error border border-error/30 px-2.5 py-1.5 hover:bg-error hover:text-on-error transition-colors">Borrar</button>
        </div>
      `;
      listEl.appendChild(row);

      row.querySelector(`[data-edit="${ev.id}"]`)?.addEventListener("click", () => editEvento(ev));
      row.querySelector(`[data-delete="${ev.id}"]`)?.addEventListener("click", () => deleteEvento(ev.id));
    });
  }

  function editEvento(ev: Evento) {
    if (idInput) idInput.value = ev.id;
    if (artistaInput) artistaInput.value = ev.artista;
    if (generoInput) generoInput.value = ev.genero ?? "";
    if (fechaInput) fechaInput.value = ev.fecha;
    if (horaInput) horaInput.value = ev.hora.slice(0, 5);
    if (descripcionInput) descripcionInput.value = ev.descripcion ?? "";
    currentImagenUrl = ev.imagen_url;
    if (imagenPreview && ev.imagen_url) {
      imagenPreview.src = ev.imagen_url;
      imagenPreview.classList.remove("hidden");
    }
    if (formTitle) formTitle.textContent = "Editar evento";
    cancelBtn?.classList.remove("hidden");
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  async function deleteEvento(id: string) {
    if (!window.confirm("¿Borrar este evento?")) return;
    const { error } = await supabase.from("eventos").delete().eq("id", id);
    if (error) {
      window.alert("No se pudo borrar: " + error.message);
      return;
    }
    loadEventos();
  }

  imagenInput?.addEventListener("change", () => {
    const file = imagenInput.files?.[0];
    if (!file || !imagenPreview) return;
    imagenPreview.src = URL.createObjectURL(file);
    imagenPreview.classList.remove("hidden");
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl?.classList.add("hidden");
    statusEl?.classList.add("hidden");
    if (submitBtn) submitBtn.disabled = true;

    try {
      let imagenUrl = currentImagenUrl;
      const file = imagenInput?.files?.[0];
      if (file) {
        const path = `${Date.now()}-${file.name.replace(/\s+/g, "-")}`;
        const { error: uploadError } = await supabase.storage.from("eventos").upload(path, file);
        if (uploadError) throw uploadError;
        const { data: publicUrlData } = supabase.storage.from("eventos").getPublicUrl(path);
        imagenUrl = publicUrlData.publicUrl;
      }

      const payload = {
        artista: artistaInput?.value ?? "",
        genero: generoInput?.value || null,
        fecha: fechaInput?.value ?? "",
        hora: horaInput?.value ?? "",
        descripcion: descripcionInput?.value || null,
        imagen_url: imagenUrl,
      };

      const id = idInput?.value;
      const { error } = id
        ? await supabase.from("eventos").update(payload).eq("id", id)
        : await supabase.from("eventos").insert(payload);

      if (error) throw error;

      showStatus(id ? "Evento actualizado." : "Evento creado.");
      resetForm();
      loadEventos();
    } catch (err) {
      showError(err instanceof Error ? err.message : "Error al guardar el evento.");
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });

  loadEventos();
</script>
